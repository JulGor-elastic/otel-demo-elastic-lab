# Copy this file to vars.yml and fill in your real values.
# vars.yml is gitignored and must not be committed.

# --- Elastic Cloud Serverless (required) ---

# mOTLP ingest URL — Kibana → Add data → OpenTelemetry → Elastic Distributions
# Example: https://YOUR_PROJECT_ID.ingest.REGION.aws.elastic.cloud:443
elastic_motlp_endpoint: "https://YOUR_PROJECT_ID.ingest.REGION.aws.elastic.cloud:443"

# API key (base64) with ingest permissions for the project
elastic_api_key: "YOUR_BASE64_API_KEY"

# Kibana onboarding ID — Add data → Kubernetes → OpenTelemetry / EDOT
edot_onboarding_id: "00000000-0000-0000-0000-000000000000"

# Derived automatically from elastic_motlp_endpoint (set here only to override):
# elastic_es_endpoint: "https://YOUR_PROJECT_ID.es.REGION.aws.elastic.cloud"
# elastic_prometheus_remote_write_url: "https://YOUR_PROJECT_ID.ingest.REGION.aws.elastic.cloud/api/v1/write"

# PRW normalizes hyphens → underscores in the ES data stream name (otel-demo → otel_demo)
prometheus_data_stream_dataset: "otel_demo"
prometheus_data_stream_namespace: "default"
prometheus_retention: "30m"
prometheus_retention_size: "128MB"
prometheus_scrape_interval: "15s"

# --- Pinned Helm chart versions ---
helm_chart_opentelemetry_demo_version: "0.40.9"
helm_chart_edot_kube_stack_version: "0.12.4"
elastic_agent_ref: "v9.4.2"

# --- OTel Demo ---
otel_demo_release_name: "my-otel-demo"
otel_demo_namespace: "otel-demo"
# Seconds for kubectl wait / rollout status in wait-otel-demo-ready.sh (per phase, not total).
otel_demo_wait_timeout: "180"

# --- Optional: Demo scenarios (GitHub Actions + Elastic Workflows) ---
# See docs/demo-scenarios-setup.md
kibana_url: "https://YOUR_PROJECT_ID.kb.REGION.aws.elastic.cloud"
github_http_connector_id: "otel-demo-github"
github_repo_owner: "YOUR_GITHUB_USER_OR_ORG"
github_repo_name: "YOUR_REPO_NAME"
github_ref: "main"

# --- Optional: Synthetics Private Location ---
# See docs/phase2-synthetics.md
fleet_url: "https://YOUR_PROJECT.fleet.REGION.aws.elastic.cloud:443"
fleet_enrollment_token: "YOUR_FLEET_ENROLLMENT_TOKEN"
fleet_agent_policy_name: "OTel Demo Synthetics"
synthetics_private_location_name: "Private Location IaaS Demo OTel"
